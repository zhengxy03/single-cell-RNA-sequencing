library(dplyr)
library(tidyr)
library(ggplot2)
library(stringr)

# 1. 数据读取与预处理（整合N0/N>0 + T大小分组）
df <- read.csv("clinical_info1.csv", stringsAsFactors = FALSE)
df_clean <- df %>%
  mutate(
    # 提取T/N分期并转数值
    T_stage = str_extract(Pre.treatment.TNM, "T[0-9]+[a-c]?"),
    N_stage = str_extract(Pre.treatment.TNM, "N[0-9]+"),
    T_numeric = as.numeric(str_extract(T_stage, "[0-9]+")),
    N_numeric = as.numeric(str_extract(N_stage, "[0-9]+")),
    
    # 定义双因素分组
    T_size = case_when(
      T_numeric %in% c(1,2) ~ "T-small (T1-2)",
      T_numeric %in% c(3,4) ~ "T-large (T3-4)"
    ),
    N_status = case_when(
      N_numeric == 0 ~ "N0",
      N_numeric > 0 ~ "N>0"
    ),
    # 简化病理反应
    Response_simple = case_when(
      Pathological.Response == "pCR" ~ "pCR",
      Pathological.Response == "MPR" ~ "MPR",
      TRUE ~ "non-MPR"
    ),
    # 因子顺序（保证图表顺序一致）
    Response_simple = factor(Response_simple, levels = c("pCR", "MPR", "non-MPR")),
    T_size = factor(T_size, levels = c("T-small (T1-2)", "T-large (T3-4)")),
    N_status = factor(N_status, levels = c("N0", "N>0")),
    pathology = factor(pathology, levels = c("LUAD", "LUSC"))
  ) %>%
  # 过滤有效分组（排除T/N分期不明确的样本）
  filter(!is.na(T_size) & !is.na(N_status))

# 2. 定义病理类型循环
pathology_types <- c("LUAD", "LUSC")

# ========== 图1：同一T大小下，N状态对缓解率的影响（添加n标注） ==========
for (path_type in pathology_types) {
  df_subset <- df_clean %>% filter(pathology == path_type)
  if (nrow(df_subset) == 0) {
    cat(sprintf("\n%s: 无有效数据（图1）\n", path_type))
    next
  }
  
  # 统计百分比
  plot_data <- df_subset %>%
    group_by(T_size, N_status, Response_simple) %>%
    summarise(count = n(), .groups = "drop") %>%
    group_by(T_size, N_status) %>%
    mutate(percent = count/sum(count)*100, percent_label = sprintf("%.1f%%", percent)) %>%
    ungroup()
  
  # 新增：计算每组（T_size + N_status）的总样本数（用于标注n=XXX）
  total_n_data <- plot_data %>%
    group_by(T_size, N_status) %>%
